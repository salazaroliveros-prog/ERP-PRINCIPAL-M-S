# Public frontend build variable for Gemini features.
# IMPORTANT: This value becomes part of frontend bundle at build time.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional backward compatibility variable used by older AI Studio templates.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public API base URL for frontend requests to the SQL backend.
# Use full HTTPS URL in production and avoid trailing slash.
# Example: VITE_API_BASE_URL="https://api.my-domain.com"
VITE_API_BASE_URL="http://localhost:3000"

# Google Sign-In OAuth client ID for frontend login button.
# Create a Web OAuth client in Google Cloud and add your app origins.
# Example: VITE_GOOGLE_CLIENT_ID="1234567890-abc123def456.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID=""

# Production API URL used by scripts/verify-production.mjs
# Keep this as your backend HTTP URL (Vercel/Render/Railway), never a postgresql:// URL.
API_BASE_URL="https://erp-principal-m-s.vercel.app"

# Frontend origin used for CORS preflight checks in scripts/verify-production.mjs
FRONTEND_ORIGIN="https://salazaroliveros-prog.github.io"

# App URL used by scripts/verify-pwa-icons.mjs
APP_URL="https://salazaroliveros-prog.github.io/ERP-PRINCIPAL-M-S"

# Optional performance controls.
# Set to "false" to disable route prefetching in frontend runtime.
VITE_PREFETCH_ENABLED="true"

# Development-only route prefetch metrics in browser console.
# Ignored in production builds.
VITE_NAV_METRICS="false"

# Backend PostgreSQL connection string used by server.ts and scripts/migrate.ts
# Encode spaces in DB name (e.g., ERP PRINCIPAL -> ERP%20PRINCIPAL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ERP%20PRINCIPAL"

# Set to disable for local postgres without TLS; otherwise keep unset or require
PGSSLMODE="disable"

# Optional CORS origins for backend API
# Example: CORS_ORIGINS="http://localhost:5173,https://your-frontend-domain"
CORS_ORIGINS="http://localhost:5173"
