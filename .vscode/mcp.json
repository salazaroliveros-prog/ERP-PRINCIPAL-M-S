{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"console-ninja": {
			"command": "powershell.exe",
			"args": [
				"node",
				"$Env:USERPROFILE/.console-ninja/mcp/"
			],
			"type": "stdio"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}